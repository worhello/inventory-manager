{
  "name": "inventory-manager",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "ghdeploy": "ng deploy --base-href=\"https://worhello.github.io/inventory-manager/\"",
    "format:fix": "pretty-quick --staged",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "precommit": "run-s format:fix lint:fix",
    "analyze-bundle": "ng build --configuration=analyze-bundle && source-map-explorer dist/**/*.js --no-border-checks"
  },
  "private": false,
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "@angular/cdk": "^21.0",
    "@angular/common": "^21.0",
    "@angular/compiler": "^21.0",
    "@angular/core": "^21.0",
    "@angular/forms": "^21.0",
    "@angular/material": "^21.0",
    "@angular/platform-browser": "^21.0",
    "@angular/router": "^21.0",
    "rxjs": "^7.8.2",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0",
    "@angular/cli": "^21.0",
    "@angular/compiler-cli": "^21.0",
    "@eslint/js": "^10.0.1",
    "@types/uuid": "^10.0.0",
    "angular-cli-ghpages": "^3.0.2",
    "angular-eslint": "^21.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "pretty-quick": "^4.2.2",
    "source-map-explorer": "^2.5.3",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.56.1",
    "uuid": "^14.0.0",
    "vitest": "^4.0.8"
  }
}
